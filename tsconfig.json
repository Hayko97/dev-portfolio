{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "isolatedModules": true,

        "lib": ["ESNext", "DOM", "DOM.Iterable", "esnext.disposable"],
        "types": ["vite/client", "node"],
        "skipLibCheck": true,

        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"]
        }
    },
    "include": ["resources/js/**/*", "resources/views/**/*", "vite.config.ts"]
}
